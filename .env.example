# ===== Data Provider =====
# 留空或不填则启用基础模式,仅使用当前适配层可公开获取的基础数据
TICKFLOW_API_KEY=

# ===== AI(可选,留空跳过 AI 功能) =====
AI_PROVIDER=openai_compat          # openai_compat | ollama
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=
AI_MODEL=deepseek-chat
AI_DAILY_TOKEN_BUDGET=500000

# ===== Server =====
HOST=0.0.0.0
PORT=3018
LOG_LEVEL=INFO

# ===== Data =====
DATA_DIR=./data
