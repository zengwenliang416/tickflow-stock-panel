# ===== Data Provider =====
# 默认使用 Longbridge 本机 OAuth；可改为 free 或 tickflow
MARKET_DATA_PROVIDER=longbridge
TICKFLOW_API_KEY=

# ===== Crypto / OKX =====
# 公共行情无需 key；私有账户/交易接口才需要 API_KEY/SECRET/PASSPHRASE。
OKX_BASE_URL=https://www.okx.com
OKX_SYMBOLS=BTC-USDT,ETH-USDT,SOL-USDT,OKB-USDT,XRP-USDT,DOGE-USDT
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

# ===== AI(可选,留空跳过 AI 功能) =====
AI_PROVIDER=openai_compat          # openai_compat | ollama
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=
AI_MODEL=deepseek-chat
AI_DAILY_TOKEN_BUDGET=500000

# ===== Server =====
HOST=0.0.0.0
PORT=3018
LOG_LEVEL=INFO

# ===== Data =====
DATA_DIR=./data
